{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "الصلاحيات الافتراضية لتطبيق Easy Store ERP — وصول لقراءة/كتابة مجلد بيانات التطبيق ومعلومات النظام.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-app-data-read",
    "fs:allow-app-data-write",
    "fs:allow-create",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-write-file",
    "os:default"
  ]
}
