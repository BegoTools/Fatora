{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Easy Store ERP",
  "version": "1.0.0",
  "identifier": "com.easystore.erp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Easy Store ERP",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://generativelanguage.googleapis.com https://*.googleapis.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Easy Store",
    "category": "Finance",
    "shortDescription": "نظام محاسبي ومخازني متكامل",
    "longDescription": "Easy Store ERP — نظام محاسبي ومخازني لوكل بالكامل، يعمل بدون إنترنت وبدون سيرفر، كل البيانات على جهاز المستخدم."
  }
}
